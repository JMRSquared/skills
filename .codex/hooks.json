{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/wh-session-start.js",
            "timeout": 5,
            "statusMessage": "Loading wonderhire-standards"
          }
        ]
      }
    ]
  }
}
